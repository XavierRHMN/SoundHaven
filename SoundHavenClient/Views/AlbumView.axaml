<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="SoundHaven.Views.AlbumView"
             x:DataType="viewModels:AlbumViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.TrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="TextBlock.TrackTitle.Playing">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.TrackMeta">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="Button.AlbumHeroAction">
            <Setter Property="Height" Value="56" />
            <Setter Property="Width" Value="220" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="48" />
        </Style>

        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#14FFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>

        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#1FFFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <SolidColorBrush x:Key="MaterialSelectionBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.1" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource ToolbarColor}">

        <!-- Album header -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="32,28,32,4"
              IsVisible="{Binding HasAlbum}">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <Border Grid.Column="0"
                        Width="288"
                        Height="288"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Margin="0,0,48,0"
                        Background="#1A1A1A"
                        BoxShadow="0 16 40 0 #60000000"
                        VerticalAlignment="Top">
                    <Panel>
                        <Border Background="#3A3A3A"
                                IsVisible="{Binding Album.Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                        <Image Source="{Binding Album.Artwork}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding Album.Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Panel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ALBUM"
                               FontSize="12"
                               LetterSpacing="1.2"
                               Foreground="#B3B3B3"
                               Margin="0,0,0,10"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                    <TextBlock Text="{Binding AlbumTitle}"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="White"
                               LineHeight="64"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                    <TextBlock Text="{Binding AlbumArtist}"
                               Margin="0,12,0,0"
                               FontSize="18"
                               Foreground="White"
                               TextTrimming="CharacterEllipsis"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                    <TextBlock Text="{Binding TrackStatsText}"
                               Margin="0,22,0,0"
                               FontSize="12"
                               Foreground="#B3B3B3"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="14"
                        Margin="0,20,0,8"
                        VerticalAlignment="Center">
                <Button Classes="AlbumHeroAction"
                        Command="{Binding PlayAlbumCommand}"
                        Background="White"
                        Foreground="#111111"
                        BorderThickness="0"
                        ToolTip.Tip="Play album">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                             Width="22" Height="22"
                             Css="path { fill: #111111; }" />
                        <TextBlock Text="Play"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="#111111"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                    </StackPanel>
                </Button>

                <Button Classes="AlbumHeroAction"
                        Command="{Binding ShuffleAlbumCommand}"
                        Background="#2A2A2A"
                        Foreground="White"
                        BorderThickness="0"
                        ToolTip.Tip="Shuffle album">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Svg Path="avares://SoundHavenClient/Assets/Icons/shuffle.svg"
                             Width="22" Height="22" />
                        <TextBlock Text="Shuffle"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Track list -->
        <DataGrid x:Name="TrackGrid"
                  Grid.Row="1"
                  Margin="16,0,16,16"
                  ItemsSource="{Binding TrackRows}"
                  SelectionChanged="OnSelectionChanged"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="False"
                  CanUserSortColumns="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="#" Width="48">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Number}"
                                           Classes="TrackMeta"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding !IsCurrentlyPlaying}" />
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/sound.svg"
                                     Width="14" Height="14"
                                     IsVisible="{Binding IsCurrentlyPlaying}" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TITLE" Width="2.4*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Title}"
                                       Classes="TrackTitle"
                                       Classes.Playing="{Binding IsCurrentlyPlaying}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ARTIST" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Artist}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TIME" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Duration, Converter={StaticResource TimeSpanToMinutesSecondsConverter}}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Loading spinner while the track list is fetched -->
        <ProgressBar Grid.Row="1"
                     Classes="circular"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Width="40" Height="40"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="{DynamicResource PrimaryColor}" />
    </Grid>
</UserControl>
