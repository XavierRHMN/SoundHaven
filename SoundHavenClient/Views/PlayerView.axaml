<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:SoundHaven.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SoundHaven.Views.PlayerView"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:ripple="clr-namespace:Material.Ripple;assembly=Material.Ripple"
             x:DataType="viewModels:PlayerViewModel">

    <UserControl.Styles>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected /template/ Border#PART_HoverEffect">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="ListBoxItem:pressed /template/ ripple|RippleEffect#PART_Ripple">
            <Setter Property="RippleFill" Value="Transparent" />
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <Style Selector="TextBlock.Headers">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="20" />
        </Style>

        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>

        <Style Selector="TextBlock.ArtworkTrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Margin" Value="0 20 0 0" />
        </Style>

        <Style Selector="TextBlock.ArtworkArtistName">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.SongTrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.SongArtistName">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.EmptyQueueHint">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *" Background="{StaticResource ToolbarColor}">
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryColor}"
                CornerRadius="0,0,10,10"
                Padding="0,15">
            <Border.Transitions>
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.5" />
                </Transitions>
            </Border.Transitions>

            <TextBlock Text="{Binding ActivePlaylistName}"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="Black"
                       Classes="Headers" />
        </Border>

        <Grid Grid.Row="1" MinWidth="900">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.7*" MinWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="0.3*" MinWidth="40" />
            </Grid.ColumnDefinitions>

            <!-- Cover + title scale together to fill the left pane, then stay centered in it. -->
            <Grid Grid.Column="0" Margin="24,24,16,24">
                <Viewbox Stretch="Uniform"
                         StretchDirection="Both"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch">
                    <StackPanel Width="520">
                        <Border x:Name="AlbumCoverBorder"
                                Width="520"
                                Height="520"
                                CornerRadius="12"
                                ClipToBounds="True"
                                HorizontalAlignment="Center">
                            <Image Source="{Binding PlayerViewSong.Artwork}"
                                   Stretch="Uniform" />
                        </Border>
                        <TextBlock Text="{Binding PlayerViewSong.Title}"
                                   Classes="ArtworkTrackTitle"
                                   Width="520"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding PlayerViewSong.Artist}"
                                   Classes="ArtworkArtistName"
                                   Width="520"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Viewbox>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="30"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="Transparent">
                <GridSplitter.Template>
                    <ControlTemplate>
                        <Grid Background="{TemplateBinding Background}">
                            <Rectangle x:Name="SplitterLine"
                                       Width="1"
                                       Fill="White"
                                       Opacity="0"
                                       VerticalAlignment="Stretch"
                                       HorizontalAlignment="Center" />
                            <Svg x:Name="SplitterIcon"
                                 Path="avares://SoundHavenClient/Assets/Icons/splitter.svg"
                                 Width="30" Height="30"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Opacity="0" />
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
                <GridSplitter.Styles>
                    <Style Selector="GridSplitter:pointerover /template/ Rectangle#SplitterLine">
                        <Setter Property="Opacity" Value="0.1" />
                    </Style>
                    <Style Selector="GridSplitter:pointerover /template/ Svg#SplitterIcon">
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </GridSplitter.Styles>
            </GridSplitter>

            <!-- Right Column: Playing + Up Next -->
            <ScrollViewer Grid.Column="2"
                          Margin="0,0,20,0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          Theme="{StaticResource MaterialModernScrollViewer}">
                <StackPanel Margin="0,16,0,16">
                    <TextBlock Text="Playing"
                               Classes="SectionHeader"
                               HorizontalAlignment="Left" />
                    <Rectangle Height="1"
                               Fill="White"
                               Opacity="0.1"
                               IsHitTestVisible="False"
                               Margin="0,0,0,8" />

                    <Border IsVisible="{Binding HasPlayingSong}"
                            Background="#14FFFFFF"
                            CornerRadius="8"
                            Padding="8"
                            Margin="0,0,0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0"
                                    CornerRadius="5"
                                    ClipToBounds="True"
                                    Margin="0,0,10,0">
                                <Image Width="50"
                                       Height="50"
                                       Source="{Binding PlayerViewSong.Artwork}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Orientation="Vertical"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding PlayerViewSong.Title}"
                                           Classes="SongTrackTitle"
                                           Foreground="{DynamicResource PrimaryColor}" />
                                <TextBlock Text="{Binding PlayerViewSong.Artist}"
                                           Classes="SongArtistName" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Text="Nothing playing"
                               Classes="EmptyQueueHint"
                               IsVisible="{Binding !HasPlayingSong}" />

                    <TextBlock Text="Up Next"
                               Classes="SectionHeader"
                               HorizontalAlignment="Left" />
                    <Rectangle Height="1"
                               Fill="White"
                               Opacity="0.1"
                               IsHitTestVisible="False"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Queue is empty — use Play next from search"
                               Classes="EmptyQueueHint"
                               IsVisible="{Binding !HasUpNextSongs}" />

                    <ListBox x:Name="UpNextList"
                             ItemsSource="{Binding UpNextSongs}"
                             Background="Transparent"
                             Theme="{StaticResource MaterialModernListBox}"
                             SelectedItem="{Binding PlayerViewSong, Mode=OneWay}"
                             SelectionChanged="OnSelectionChanged"
                             IsVisible="{Binding HasUpNextSongs}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                      Margin="0,2">
                                    <Border Grid.Column="0"
                                            Width="28"
                                            Height="50"
                                            Background="Transparent"
                                            Cursor="SizeAll"
                                            ToolTip.Tip="Drag to reorder"
                                            PointerPressed="OnDragHandlePointerPressed"
                                            PointerMoved="OnDragHandlePointerMoved"
                                            PointerReleased="OnDragHandlePointerReleased"
                                            PointerCaptureLost="OnDragHandlePointerCaptureLost">
                                        <Svg Path="avares://SoundHavenClient/Assets/Icons/drag_handle.svg"
                                             Width="18"
                                             Height="18"
                                             Stretch="Uniform"
                                             Opacity="0.45"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             IsHitTestVisible="False" />
                                    </Border>

                                    <Border Grid.Column="1"
                                            CornerRadius="5"
                                            ClipToBounds="True"
                                            Margin="0,0,10,0">
                                        <Image Width="50"
                                               Height="50"
                                               Source="{Binding Artwork}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Vertical"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Classes="SongTrackTitle" />
                                        <TextBlock Text="{Binding Artist}"
                                                   Classes="SongArtistName" />
                                    </StackPanel>

                                    <Border Grid.Column="3"
                                            Width="32"
                                            Height="50"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            ToolTip.Tip="Remove from Up Next"
                                            PointerPressed="OnRemoveFromUpNextPointerPressed">
                                        <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                                             Width="16"
                                             Height="16"
                                             Stretch="Uniform"
                                             Opacity="0.55"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"
                                             IsHitTestVisible="False" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
