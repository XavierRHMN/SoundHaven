<UserControl x:Class="SoundHaven.Views.HomeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SoundHaven.ViewModels"
             xmlns:models="clr-namespace:SoundHaven.Models"
             xmlns:controls="clr-namespace:SoundHaven.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignWidth="1500" d:DesignHeight="800"
             x:DataType="vm:HomeViewModel">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Square media card: art, hover play, hover overflow, title/artist -->
            <DataTemplate x:Key="SongCardTemplate" x:DataType="models:Song">
                <Border Classes="SongCard"
                        DoubleTapped="OnSongDoubleTapped"
                        PointerPressed="OnSongCardPointerPressed">
                    <StackPanel Spacing="10">
                        <Panel Width="160" Height="160">
                            <Border CornerRadius="8"
                                    ClipToBounds="True"
                                    Background="#2A2A2A">
                                <Panel>
                                    <Border Background="#3A3A3A"
                                            IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                    <Image Source="{Binding Artwork}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </Panel>
                            </Border>

                            <Button Classes="CardOverflow"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,6,6,0"
                                    PointerPressed="OnActionsPointerPressed"
                                    Click="OnSongOverflowClick"
                                    ToolTip.Tip="More options">
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                     Width="18" Height="18" />
                            </Button>

                            <Button Classes="CardPlay"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,8,8"
                                    Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlaySongCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="Play">
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                                     Width="20" Height="20"
                                     Css="path { fill: #111111; }" />
                            </Button>
                        </Panel>

                        <StackPanel Spacing="3" Width="160">
                            <TextBlock Text="{Binding Title}" Classes="CardTitle" />
                            <TextBlock Text="{Binding Artist}" Classes="CardSubtitle" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>

            <!-- Album card: same look, no overflow menu (albums aren't queueable rows) -->
            <DataTemplate x:Key="AlbumCardTemplate" x:DataType="models:Song">
                <Border Classes="SongCard"
                        PointerPressed="OnAlbumCardPressed"
                        ToolTip.Tip="Open album">
                    <StackPanel Spacing="10">
                        <Panel Width="160" Height="160">
                            <Border CornerRadius="8"
                                    ClipToBounds="True"
                                    Background="#2A2A2A">
                                <Panel>
                                    <Border Background="#3A3A3A"
                                            IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                    <Image Source="{Binding Artwork}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </Panel>
                            </Border>

                            <Button Classes="CardPlay"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,8,8"
                                    Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlayAlbumCommand}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="Play album">
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                                     Width="20" Height="20"
                                     Css="path { fill: #111111; }" />
                            </Button>
                        </Panel>

                        <StackPanel Spacing="3" Width="160">
                            <TextBlock Text="{Binding Title}" Classes="CardTitle" />
                            <TextBlock Text="{Binding Artist}" Classes="CardSubtitle" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.HomePill">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.HomePill.Selected">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style Selector="Button.HomePill:not(.Selected)">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.IconOnly">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.IconOnly:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.LinkButton">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.LinkButton:pointerover">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="TextBlock.Greeting">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="32" />
        </Style>

        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="22" />
        </Style>

        <Style Selector="TextBlock.SectionSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style Selector="TextBlock.RowTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Liked Songs card name tracks the dynamic accent like its tile. -->
        <Style Selector="TextBlock.RowTitle.LikedName">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.RowTitle.Playing">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.RowSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.CardTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.CardSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#9A9A9A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.HeroCard">
            <Setter Property="Background" Value="#1F1F1F" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.HeroCard:pointerover">
            <Setter Property="Background" Value="#2E2E2E" />
        </Style>

        <!-- "New playlist" call-to-action card: fills empty grid cells and
             reads as an action rather than a playlist. -->
        <Style Selector="Border.NewPlaylistCard">
            <Setter Property="Background" Value="#141414" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#30FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.NewPlaylistCard:pointerover">
            <Setter Property="Background" Value="#242424" />
        </Style>

        <!-- Media card: hover is the app-wide barely-visible translucent white,
             applied instantly so adjacent cards never show mixed fade states. -->
        <Style Selector="Border.SongCard">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Border.SongCard:pointerover">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="Button.CardPlay">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryColor}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(8px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                    <TransformOperationsTransition Property="RenderTransform"
                                                   Duration="0:0:0.18"
                                                   Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BoxShadow="0 6 16 0 #80000000">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Border.SongCard:pointerover Button.CardPlay">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0px)" />
        </Style>

        <Style Selector="Button.CardPlay:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.06)" />
        </Style>

        <Style Selector="Button.CardOverflow">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#B3121212" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Border.SongCard:pointerover Button.CardOverflow">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.CardOverflow:pointerover">
            <Setter Property="Background" Value="#E6121212" />
        </Style>

        <!-- Headers/copy indent 10px to align with card artwork; card rows stay at
             x=0 so the hover highlight outdents without being clipped by the
             ScrollViewer. Never pull rows left with negative margins — the first
             card's padding gets cut off. -->
        <Style Selector="TextBlock.CardAligned, StackPanel.CardAligned">
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <!-- Search results table -->
        <Style Selector="TextBlock.ColumnHeader">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.8" />
        </Style>

        <Style Selector="TextBlock.CellText">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="ListBox.SearchResults">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="ListBox.SearchResults ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="8,6"
                            ClipToBounds="True">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.SearchResults ListBoxItem:pointerover /template/ Border#PART_Root">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="ListBox.SearchResults ListBoxItem:selected /template/ Border#PART_Root">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <Style Selector="ListBox.SearchResults ListBoxItem Button.RowAction">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <Style Selector="ListBox.SearchResults ListBoxItem:pointerover Button.RowAction">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource ToolbarColor}" Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar: pills left, TIDAL-style search right -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,20">
            <!-- Browse pills (hidden while searching) -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        IsVisible="{Binding !Search.ShowResults}">
                <Button Classes="HomePill"
                        Classes.Selected="{Binding IsForYouSelected}"
                        Content="For you"
                        Command="{Binding ShowForYouCommand}" />
                <Button Classes="HomePill"
                        Classes.Selected="{Binding IsUploadsSelected}"
                        Content="Uploads"
                        Command="{Binding ShowUploadsCommand}" />
            </StackPanel>

            <!-- Search mode pills (shown while searching) -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        IsVisible="{Binding Search.ShowResults}">
                <Button Classes="HomePill"
                        Classes.Selected="{Binding Search.SearchSongs}"
                        Content="Songs"
                        Command="{Binding Search.SelectSongsCommand}" />
                <Button Classes="HomePill"
                        Classes.Selected="{Binding !Search.SearchSongs}"
                        Content="Videos"
                        Command="{Binding Search.SelectVideosCommand}" />
            </StackPanel>

            <!-- Account chips: sign in for personalized recommendations -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button Classes="HomePill"
                        Click="OnConnectLastFmClick"
                        IsVisible="{Binding IsLastFmConnectVisible}"
                        ToolTip.Tip="Sign in to scrobble and mix in your taste">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Svg Path="avares://SoundHavenClient/Assets/Icons/lastfm.svg"
                             Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="Connect Last.fm" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="HomePill"
                        Click="OnLastFmAccountClick"
                        IsVisible="{Binding IsLastFmConnected}"
                        ToolTip.Tip="Last.fm account connected">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Svg Path="avares://SoundHavenClient/Assets/Icons/lastfm.svg"
                             Width="15" Height="15" VerticalAlignment="Center" />
                        <TextBlock Text="Last.fm ✓" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Search bar -->
            <Border Grid.Column="2"
                    Background="#2A2A2A"
                    CornerRadius="20"
                    Height="40"
                    Width="320"
                    Padding="14,0"
                    VerticalAlignment="Center">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Svg Grid.Column="0"
                         Path="avares://SoundHavenClient/Assets/Icons/search.svg"
                         Width="16" Height="16"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"
                         Opacity="0.55" />
                    <TextBox Grid.Column="1"
                             Text="{Binding Search.SearchQuery, Mode=TwoWay}"
                             Watermark="Search"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalAlignment="Center"
                             FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                             FontSize="14"
                             Foreground="White">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter"
                                        Command="{Binding Search.SearchCommand}" />
                            <KeyBinding Gesture="Escape"
                                        Command="{Binding Search.ClearSearchCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Grid.Column="2"
                            Classes="IconOnly"
                            Width="28"
                            Height="28"
                            VerticalAlignment="Center"
                            Command="{Binding Search.ClearSearchCommand}"
                            IsVisible="{Binding Search.HasQuery}"
                            ToolTip.Tip="Clear search">
                        <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                             Width="14" Height="14"
                             Opacity="0.75" />
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Theme="{StaticResource MaterialModernScrollViewer}"
                      IsVisible="{Binding !Search.ShowResults}">
            <!-- Right margin keeps right-aligned content clear of the scrollbar -->
            <StackPanel Spacing="32" Margin="0,0,16,0">
                <!-- FOR YOU -->
                <StackPanel IsVisible="{Binding ShowForYouContent}" Spacing="32">
                    <StackPanel Spacing="24">
                        <TextBlock Text="{Binding Greeting}" Classes="Greeting CardAligned" />

                        <!-- Hero playlist grid: up to 3 per row, height fits the
                             number of items (no reserved empty rows). A trailing
                             "New playlist" card fills the shelf for small libraries. -->
                        <ItemsControl ItemsSource="{Binding FeaturedItems}"
                                      IsVisible="{Binding HasFeaturedItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.DataTemplates>
                                <DataTemplate x:DataType="models:Playlist">
                                    <Border Classes="HeroCard"
                                            Margin="0,0,12,12"
                                            PointerPressed="OnPlaylistCardPressed">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0"
                                                    Width="56"
                                                    Height="56"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Background="#3A3A3A"
                                                    Margin="0,0,12,0">
                                                <Panel>
                                                    <Border Background="#3A3A3A"
                                                            IsVisible="{Binding !HasSidebarCover}" />
                                                    <Image Source="{Binding SidebarSlot0}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasSidebarSingleCover}" />
                                                    <UniformGrid Rows="2" Columns="2"
                                                                 IsVisible="{Binding HasSidebarMosaic}">
                                                        <Image Source="{Binding SidebarSlot0}" Stretch="UniformToFill" />
                                                        <Image Source="{Binding SidebarSlot1}" Stretch="UniformToFill" />
                                                        <Image Source="{Binding SidebarSlot2}" Stretch="UniformToFill" />
                                                        <Image Source="{Binding SidebarSlot3}" Stretch="UniformToFill" />
                                                    </UniformGrid>

                                                    <!-- Liked Songs note tile -->
                                                    <Border IsVisible="{Binding IsLikedSongs}"
                                                            HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Background="Black">
                                                        <Border Background="Black"
                                                                BorderBrush="{DynamicResource PrimaryColor}"
                                                                BorderThickness="1.5"
                                                                CornerRadius="6">
                                                            <PathIcon Width="26" Height="26"
                                                                      Foreground="{DynamicResource PrimaryColor}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,1.7,0"
                                                                      Data="F1 M6 13c0 1.105-1.12 2-2.5 2S1 14.105 1 13c0-1.104 1.12-2 2.5-2s2.5.896 2.5 2zm9-2c0 1.105-1.12 2-2.5 2s-2.5-.895-2.5-2 1.12-2 2.5-2 2.5.895 2.5 2zM14 11V2h1v9zM6 3v10H5V3zM5 2.905a1 1 0 0 1 .9-.995l8-.8a1 1 0 0 1 1.1.995V3L5 4z" />
                                                        </Border>
                                                    </Border>
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Name}"
                                                           Classes="RowTitle"
                                                           Classes.LikedName="{Binding IsLikedSongs}" />
                                                <TextBlock Text="{Binding ItemCountText, StringFormat='{}{0} · Created by you'}"
                                                           Classes="RowSubtitle" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>

                                <DataTemplate x:DataType="models:NewPlaylistCard">
                                    <Border Classes="NewPlaylistCard"
                                            Margin="0,0,12,12"
                                            PointerPressed="OnNewPlaylistCardPressed"
                                            ToolTip.Tip="Create a new playlist">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    MinHeight="56"
                                                    Spacing="10">
                                            <Border Width="34"
                                                    Height="34"
                                                    CornerRadius="17"
                                                    Background="#22FFFFFF">
                                                <TextBlock Text="+"
                                                           FontSize="22"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="New playlist"
                                                       Classes="RowTitle"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Recommended for you (Last.fm + YouTube Music) -->
                    <StackPanel Spacing="12">
                        <StackPanel Classes="CardAligned">
                            <TextBlock Text="Recommended for you" Classes="SectionTitle" />
                            <TextBlock Text="{Binding RecommendationsSubtitle}"
                                       Classes="SectionSubtitle" />
                        </StackPanel>

                        <ProgressBar Classes="circular"
                                     IsIndeterminate="True"
                                     Height="48"
                                     Width="48"
                                     HorizontalAlignment="Left"
                                     Margin="10,8,0,0"
                                     IsVisible="{Binding IsLoadingRecommendations}"
                                     Foreground="{DynamicResource PrimaryColor}" />

                        <TextBlock Text="Couldn’t load recommendations right now. Check your connection, or connect Last.fm to mix in your taste."
                                   Classes="SectionSubtitle CardAligned"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding ShowRecommendationsEmpty}" />

                        <ItemsControl Classes="CardRow"
                                      ItemsSource="{Binding RecommendedSongs}"
                                      ItemTemplate="{StaticResource SongCardTemplate}"
                                      IsVisible="{Binding HasRecommendations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Your top albums (Last.fm) -->
                    <StackPanel Spacing="12" IsVisible="{Binding HasTopAlbums}">
                        <StackPanel Classes="CardAligned">
                            <TextBlock Text="Your top albums" Classes="SectionTitle" />
                            <TextBlock Text="The records you keep coming back to on Last.fm"
                                       Classes="SectionSubtitle" />
                        </StackPanel>

                        <ItemsControl Classes="CardRow"
                                      ItemsSource="{Binding TopAlbums}"
                                      ItemTemplate="{StaticResource AlbumCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Recently played -->
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Recently played" Classes="SectionTitle CardAligned" />
                            <Button Grid.Column="1"
                                    Classes="LinkButton"
                                    Content="View all"
                                    VerticalAlignment="Center"
                                    Command="{Binding ViewAllRecentlyPlayedCommand}"
                                    IsVisible="{Binding HasRecentlyPlayed}" />
                        </Grid>

                        <TextBlock Text="Play something to fill this list."
                                   Classes="SectionSubtitle CardAligned"
                                   IsVisible="{Binding !HasRecentlyPlayed}" />

                        <ItemsControl Classes="CardRow"
                                      ItemsSource="{Binding RecentlyPlayedPreview}"
                                      ItemTemplate="{StaticResource SongCardTemplate}"
                                      IsVisible="{Binding HasRecentlyPlayed}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Uploads for you -->
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Classes="CardAligned">
                                <TextBlock Text="Uploads for you" Classes="SectionTitle" />
                                <TextBlock Text="Local and downloaded tracks from your library"
                                           Classes="SectionSubtitle" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="LinkButton"
                                    Content="View all"
                                    VerticalAlignment="Top"
                                    Command="{Binding ViewAllUploadsCommand}"
                                    IsVisible="{Binding HasUploads}" />
                        </Grid>

                        <TextBlock Text="No local uploads yet — download from Search or add files to a playlist."
                                   Classes="SectionSubtitle CardAligned"
                                   IsVisible="{Binding !HasUploads}" />

                        <ItemsControl Classes="CardRow"
                                      ItemsSource="{Binding UploadSongsPreview}"
                                      ItemTemplate="{StaticResource SongCardTemplate}"
                                      IsVisible="{Binding HasUploads}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- UPLOADS TAB -->
                <StackPanel IsVisible="{Binding ShowUploadsContent}" Spacing="12">
                    <StackPanel Classes="CardAligned">
                        <TextBlock Text="Uploads for you" Classes="SectionTitle" />
                        <TextBlock Text="Local and downloaded tracks from your library"
                                   Classes="SectionSubtitle"
                                   Margin="0,4,0,8" />
                    </StackPanel>

                    <TextBlock Text="No local uploads yet — download from Search or add files to a playlist."
                               Classes="SectionSubtitle CardAligned"
                               IsVisible="{Binding !HasUploads}" />

                    <ItemsControl Classes="CardRow"
                                  ItemsSource="{Binding UploadSongs}"
                                  ItemTemplate="{StaticResource SongCardTemplate}"
                                  IsVisible="{Binding HasUploads}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- SEARCH RESULTS (replaces shelves while a search is active) -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              IsVisible="{Binding Search.ShowResults}">
            <!-- Column headers -->
            <!-- Right padding matches the rows' scrollbar-clearance margin (16)
                 plus their 8px cell padding, so header columns line up with cells. -->
            <Border Grid.Row="0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#22FFFFFF"
                    Padding="8,0,24,10">
                <Grid ColumnDefinitions="48,2.2*,*,*,64,72,96">
                    <TextBlock Text="#" Classes="ColumnHeader" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="TITLE" Classes="ColumnHeader" />
                    <TextBlock Grid.Column="2" Text="ARTIST" Classes="ColumnHeader" />
                    <TextBlock Grid.Column="3" Text="ALBUM" Classes="ColumnHeader" />
                    <TextBlock Grid.Column="4" Text="YEAR" Classes="ColumnHeader"
                               HorizontalAlignment="Right" />
                    <TextBlock Grid.Column="5" Text="TIME" Classes="ColumnHeader"
                               HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <Panel Grid.Row="1" Margin="0,8,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Theme="{StaticResource MaterialModernScrollViewer}"
                              IsVisible="{Binding !Search.IsLoading}"
                              IsHitTestVisible="{Binding Search.IsScrollViewerHittestable}">
                    <ListBox Classes="SearchResults"
                             Margin="0,0,16,0"
                             ItemsSource="{Binding Search.ResultRows}"
                             SelectionChanged="OnSearchRowSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchResultRow">
                                <Grid ColumnDefinitions="48,2.2*,*,*,64,72,96"
                                      Background="Transparent"
                                      ToolTip.Tip="{Binding Song.Title}">
                                    <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Number}"
                                                   Classes="CellText"
                                                   HorizontalAlignment="Center"
                                                   IsVisible="{Binding !IsCurrentlyPlaying}" />
                                        <Svg Path="avares://SoundHavenClient/Assets/Icons/sound.svg"
                                             Width="14" Height="14"
                                             IsVisible="{Binding IsCurrentlyPlaying}" />
                                    </Panel>

                                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*">
                                        <Border Width="40"
                                                Height="40"
                                                CornerRadius="4"
                                                ClipToBounds="True"
                                                Background="#22FFFFFF"
                                                Margin="0,0,12,0">
                                            <Panel>
                                                <Image Source="{Binding Song.Artwork}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                <controls:AsyncImageControl SourceUrl="{Binding Song.ThumbnailUrl}"
                                                                            Stretch="UniformToFill"
                                                                            IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                            </Panel>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Song.Title}"
                                                   Classes="RowTitle"
                                                   Classes.Playing="{Binding IsCurrentlyPlaying}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0" />
                                    </Grid>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Song.Artist}"
                                               Classes="CellText"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Song.Album}"
                                               Classes="CellText"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Song.Year}"
                                               Classes="CellText"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding Song.VideoDuration}"
                                               Classes="CellText"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />

                                    <StackPanel Grid.Column="6"
                                                Orientation="Horizontal"
                                                Spacing="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                PointerPressed="OnSearchActionsPointerPressed">
                                        <Button Classes="IconOnly RowAction"
                                                Width="32"
                                                Height="32"
                                                Click="OnSearchOverflowClick"
                                                ToolTip.Tip="More options">
                                            <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                                 Width="18" Height="18"
                                                 Opacity="0.75" />
                                        </Button>

                                        <Grid Width="32" Height="32">
                                            <Button Classes="IconOnly RowAction"
                                                    Width="32"
                                                    Height="32"
                                                    Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).Search.DownloadSongCommand}"
                                                    CommandParameter="{Binding Song}"
                                                    IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.NotDownloaded}}"
                                                    ToolTip.Tip="Download">
                                                <Svg Path="avares://SoundHavenClient/Assets/Icons/download.svg"
                                                     Width="18" Height="18"
                                                     Opacity="0.75" />
                                            </Button>

                                            <ProgressBar Classes="circular"
                                                         IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.Downloading}}"
                                                         Value="{Binding Song.DownloadProgress}"
                                                         Foreground="{DynamicResource PrimaryColor}"
                                                         Width="24"
                                                         Height="24" />

                                            <Button Classes="IconOnly"
                                                    Width="32"
                                                    Height="32"
                                                    IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.Downloaded}}"
                                                    Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).Search.OpenFolderCommand}"
                                                    CommandParameter="{Binding Song}"
                                                    ToolTip.Tip="Open folder">
                                                <Svg Path="avares://SoundHavenClient/Assets/Icons/folder.svg"
                                                     Width="18" Height="18"
                                                     Opacity="0.75" />
                                            </Button>
                                        </Grid>

                                        <Button Classes="IconOnly RowAction"
                                                Width="32"
                                                Height="32"
                                                Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).Search.ToggleLikeCommand}"
                                                CommandParameter="{Binding Song}"
                                                ToolTip.Tip="Add to Liked Songs">
                                            <Panel>
                                                <PathIcon Width="17" Height="17"
                                                          Foreground="#B3B3B3"
                                                          IsVisible="{Binding !IsLiked}"
                                                          Data="M16.5,3c-1.74,0-3.41,0.81-4.5,2.09C10.91,3.81,9.24,3,7.5,3C4.42,3,2,5.42,2,8.5c0,3.78,3.4,6.86,8.55,11.54L12,21.35l1.45-1.32C18.6,15.36,22,12.28,22,8.5C22,5.42,19.58,3,16.5,3z M12.1,18.55l-0.1,0.1l-0.1-0.1C7.14,14.24,4,11.39,4,8.5C4,6.5,5.5,5,7.5,5c1.54,0,3.04,0.99,3.57,2.36h1.87C13.46,5.99,14.96,5,16.5,5c2,0,3.5,1.5,3.5,3.5C20,11.39,16.86,14.24,12.1,18.55z" />
                                                <PathIcon Width="17" Height="17"
                                                          Foreground="{DynamicResource PrimaryColor}"
                                                          IsVisible="{Binding IsLiked}"
                                                          Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" />
                                            </Panel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <TextBlock Text="No results found — try a different search."
                           Classes="SectionSubtitle"
                           HorizontalAlignment="Center"
                           Margin="0,32,0,0"
                           IsVisible="{Binding Search.ShowNoResults}" />

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="16"
                            IsVisible="{Binding Search.IsLoading}">
                    <ProgressBar Classes="circular"
                                 IsIndeterminate="True"
                                 Height="56"
                                 Width="56"
                                 Foreground="{DynamicResource PrimaryColor}" />
                    <TextBlock Text="{Binding Search.LoadingMessage}"
                               Classes="SectionSubtitle"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Panel>
        </Grid>
    </Grid>
</UserControl>
