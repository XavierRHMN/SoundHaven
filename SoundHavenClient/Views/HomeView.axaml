<UserControl x:Class="SoundHaven.Views.HomeView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SoundHaven.ViewModels"
             xmlns:models="clr-namespace:SoundHaven.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignWidth="1500" d:DesignHeight="800"
             x:DataType="vm:HomeViewModel">

    <UserControl.Styles>
        <Style Selector="Button.HomePill">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.HomePill.Selected">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style Selector="Button.HomePill:not(.Selected)">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.IconOnly">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.IconOnly:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.LinkButton">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#B3B3B3" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="22" />
        </Style>

        <Style Selector="TextBlock.SectionSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style Selector="TextBlock.RowTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.RowSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.HeroCard">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Border.HeroCard:pointerover">
            <Setter Property="Background" Value="#242424" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource ToolbarColor}" Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Pills: For you | Uploads -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="0,0,0,20">
            <Button Classes="HomePill"
                    Classes.Selected="{Binding IsForYouSelected}"
                    Content="For you"
                    Command="{Binding ShowForYouCommand}" />
            <Button Classes="HomePill"
                    Classes.Selected="{Binding IsUploadsSelected}"
                    Content="Uploads"
                    Command="{Binding ShowUploadsCommand}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Theme="{StaticResource MaterialModernScrollViewer}">
            <StackPanel Spacing="28">
                <!-- FOR YOU -->
                <StackPanel IsVisible="{Binding ShowForYouContent}" Spacing="28">
                    <!-- Hero playlist grid 2x3 -->
                    <ItemsControl ItemsSource="{Binding FeaturedPlaylists}"
                                  IsVisible="{Binding HasFeaturedPlaylists}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" Rows="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Playlist">
                                <Border Classes="HeroCard"
                                        Margin="0,0,12,12"
                                        PointerPressed="OnPlaylistCardPressed">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0"
                                                Width="56"
                                                Height="56"
                                                CornerRadius="6"
                                                ClipToBounds="True"
                                                Background="#3A3A3A"
                                                Margin="0,0,12,0">
                                            <Panel>
                                                <Border Background="#3A3A3A"
                                                        IsVisible="{Binding !HasSidebarCover}" />
                                                <Image Source="{Binding SidebarSlot0}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding HasSidebarSingleCover}" />
                                                <UniformGrid Rows="2" Columns="2"
                                                             IsVisible="{Binding HasSidebarMosaic}">
                                                    <Image Source="{Binding SidebarSlot0}" Stretch="UniformToFill" />
                                                    <Image Source="{Binding SidebarSlot1}" Stretch="UniformToFill" />
                                                    <Image Source="{Binding SidebarSlot2}" Stretch="UniformToFill" />
                                                    <Image Source="{Binding SidebarSlot3}" Stretch="UniformToFill" />
                                                </UniformGrid>
                                            </Panel>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Classes="RowTitle" />
                                            <TextBlock Text="{Binding ItemCountText, StringFormat='{}{0} · Created by you'}"
                                                       Classes="RowSubtitle" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Recommended for you (Last.fm + YouTube Music) -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Recommended for you" Classes="SectionTitle" />
                        <TextBlock Text="Mixed from YouTube Music and your Last.fm taste"
                                   Classes="SectionSubtitle" />

                        <ProgressBar Classes="circular"
                                     IsIndeterminate="True"
                                     Height="48"
                                     Width="48"
                                     HorizontalAlignment="Left"
                                     Margin="0,8,0,0"
                                     IsVisible="{Binding IsLoadingRecommendations}"
                                     Foreground="{DynamicResource PrimaryColor}" />

                        <TextBlock Text="Couldn’t load recommendations right now. Check your connection, or sign in on the Last.fm tab to mix in your taste."
                                   Classes="SectionSubtitle"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding ShowRecommendationsEmpty}" />

                        <ItemsControl ItemsSource="{Binding RecommendedSongs}"
                                      IsVisible="{Binding HasRecommendations}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Border Margin="0,0,16,12"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            DoubleTapped="OnSongDoubleTapped">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    Width="48"
                                                    Height="48"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Background="#3A3A3A"
                                                    Margin="0,0,12,0">
                                                <Image Source="{Binding Artwork}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Title}" Classes="RowTitle" />
                                                <TextBlock Text="{Binding Artist}" Classes="RowSubtitle" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Classes="IconOnly"
                                                    Width="32"
                                                    Height="32"
                                                    VerticalAlignment="Center"
                                                    PointerPressed="OnActionsPointerPressed"
                                                    Click="OnSongOverflowClick"
                                                    ToolTip.Tip="More options">
                                                <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                                     Width="18" Height="18"
                                                     Opacity="0.75" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Uploads for you -->
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Uploads for you" Classes="SectionTitle" />
                                <TextBlock Text="Local and downloaded tracks from your library"
                                           Classes="SectionSubtitle" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="LinkButton"
                                    Content="View all"
                                    VerticalAlignment="Top"
                                    Command="{Binding ViewAllUploadsCommand}"
                                    IsVisible="{Binding HasUploads}" />
                        </Grid>

                        <TextBlock Text="No local uploads yet — download from Search or add files to a playlist."
                                   Classes="SectionSubtitle"
                                   IsVisible="{Binding !HasUploads}" />

                        <ItemsControl ItemsSource="{Binding UploadSongsPreview}"
                                      IsVisible="{Binding HasUploads}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Border Margin="0,0,16,12"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            DoubleTapped="OnSongDoubleTapped">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    Width="48"
                                                    Height="48"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Background="#3A3A3A"
                                                    Margin="0,0,12,0">
                                                <Image Source="{Binding Artwork}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Title}" Classes="RowTitle" />
                                                <TextBlock Text="{Binding Artist}" Classes="RowSubtitle" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Classes="IconOnly"
                                                    Width="32"
                                                    Height="32"
                                                    VerticalAlignment="Center"
                                                    PointerPressed="OnActionsPointerPressed"
                                                    Click="OnSongOverflowClick"
                                                    ToolTip.Tip="More options">
                                                <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                                     Width="18" Height="18"
                                                     Opacity="0.75" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Recently played -->
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Recently played" Classes="SectionTitle" />
                            <Button Grid.Column="1"
                                    Classes="LinkButton"
                                    Content="View all"
                                    VerticalAlignment="Top"
                                    Command="{Binding ViewAllRecentlyPlayedCommand}"
                                    IsVisible="{Binding HasRecentlyPlayed}" />
                        </Grid>

                        <TextBlock Text="Play something to fill this list."
                                   Classes="SectionSubtitle"
                                   IsVisible="{Binding !HasRecentlyPlayed}" />

                        <ItemsControl ItemsSource="{Binding RecentlyPlayedPreview}"
                                      IsVisible="{Binding HasRecentlyPlayed}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Song">
                                    <Border Margin="0,0,16,12"
                                            Background="Transparent"
                                            Cursor="Hand"
                                            DoubleTapped="OnSongDoubleTapped">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Border Grid.Column="0"
                                                    Width="48"
                                                    Height="48"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    Background="#3A3A3A"
                                                    Margin="0,0,12,0">
                                                <Image Source="{Binding Artwork}"
                                                       Stretch="UniformToFill" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Title}" Classes="RowTitle" />
                                                <TextBlock Text="{Binding Artist}" Classes="RowSubtitle" />
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    Classes="IconOnly"
                                                    Width="32"
                                                    Height="32"
                                                    VerticalAlignment="Center"
                                                    PointerPressed="OnActionsPointerPressed"
                                                    Click="OnSongOverflowClick"
                                                    ToolTip.Tip="More options">
                                                <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                                     Width="18" Height="18"
                                                     Opacity="0.75" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- UPLOADS TAB -->
                <StackPanel IsVisible="{Binding ShowUploadsContent}" Spacing="10">
                    <TextBlock Text="Uploads for you" Classes="SectionTitle" />
                    <TextBlock Text="Local and downloaded tracks from your library"
                               Classes="SectionSubtitle"
                               Margin="0,0,0,12" />

                    <TextBlock Text="No local uploads yet — download from Search or add files to a playlist."
                               Classes="SectionSubtitle"
                               IsVisible="{Binding !HasUploads}" />

                    <ItemsControl ItemsSource="{Binding UploadSongs}"
                                  IsVisible="{Binding HasUploads}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Song">
                                <Border Margin="0,0,16,12"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        DoubleTapped="OnSongDoubleTapped">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                Width="48"
                                                Height="48"
                                                CornerRadius="6"
                                                ClipToBounds="True"
                                                Background="#3A3A3A"
                                                Margin="0,0,12,0">
                                            <Image Source="{Binding Artwork}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Title}" Classes="RowTitle" />
                                            <TextBlock Text="{Binding Artist}" Classes="RowSubtitle" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Classes="IconOnly"
                                                Width="32"
                                                Height="32"
                                                VerticalAlignment="Center"
                                                PointerPressed="OnActionsPointerPressed"
                                                Click="OnSongOverflowClick"
                                                ToolTip.Tip="More options">
                                            <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                                 Width="18" Height="18"
                                                 Opacity="0.75" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
