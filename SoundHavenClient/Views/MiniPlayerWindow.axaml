<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
        xmlns:controls="clr-namespace:SoundHaven.Controls"
        x:Class="SoundHaven.Views.MiniPlayerWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="SoundHaven Mini Player"
        Icon="/Assets/Icons/SoundHavenClient.ico"
        Width="320" Height="320"
        CanResize="False"
        Topmost="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="Manual">

    <Window.Styles>
        <Style Selector="Button.IconOnly">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="16"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.IconOnly:pointerover">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>

        <Style Selector="TextBlock.MiniTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.MiniArtist">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <!-- Overlay hides until the card is hovered, then fades in over darkened art -->
        <Style Selector="Grid.MiniOverlay">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.MiniRoot:pointerover Grid.MiniOverlay">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Window.Styles>

    <!-- The card IS the artwork; controls live inside it, revealed on hover -->
    <Border Classes="MiniRoot"
            CornerRadius="12"
            Background="#181818"
            ClipToBounds="True"
            PointerPressed="OnRootPointerPressed">
        <Panel>
            <Border Background="#242424" />
            <Image Source="{Binding PlaybackViewModel.CurrentSong.Artwork}"
                   Stretch="UniformToFill" />

            <Grid Classes="MiniOverlay"
                  Background="#99000000"
                  RowDefinitions="Auto,*,Auto">
                <Button Grid.Row="0"
                        Classes="IconOnly"
                        Width="34"
                        Height="34"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="10,10,0,0"
                        Click="OnCloseClick"
                        ToolTip.Tip="Back to full player">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                         Width="16" Height="16"
                         Opacity="0.9" />
                </Button>

                <StackPanel Grid.Row="2" Margin="14,0,14,8">
                    <StackPanel Margin="6,0" Spacing="2">
                        <TextBlock Classes="MiniTitle"
                                   Text="{Binding PlaybackViewModel.CurrentSong.Title, FallbackValue='Play a song!'}" />
                        <TextBlock Classes="MiniArtist"
                                   Text="{Binding PlaybackViewModel.CurrentSong.Artist, FallbackValue='Artist - 20XX'}" />
                    </StackPanel>

                    <controls:SeekSliderControl Margin="-8,2,-8,0"
                                                DataContext="{Binding SeekSliderViewModel}" />

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="2"
                                Margin="0,-4,0,0">
                        <controls:ShuffleControl DataContext="{Binding ShuffleViewModel}"
                                                 VerticalAlignment="Center" />
                        <controls:PlaybackControl DataContext="{Binding PlaybackViewModel}"
                                                  VerticalAlignment="Center" />
                        <controls:RepeatControl DataContext="{Binding RepeatViewModel}"
                                                VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Panel>
    </Border>
</Window>
