<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:models="clr-namespace:SoundHaven.Models"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="SoundHaven.Views.LikedAlbumsView"
             x:DataType="viewModels:LikedAlbumsViewModel">

    <UserControl.Styles>
        <Style Selector="Border.AlbumCard">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="Border.AlbumCard:pointerover">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="TextBlock.CardTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.CardSubtitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#A0A0A0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Button.CardPlay">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryColor}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform" Value="translateY(8px)" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Border.AlbumCard:pointerover Button.CardPlay">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="RenderTransform" Value="translateY(0px)" />
        </Style>

        <Style Selector="Button.CardLike">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#B3121212" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Border.AlbumCard:pointerover Button.CardLike">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.CardLike:pointerover">
            <Setter Property="Background" Value="#E6121212" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Background="{DynamicResource ToolbarColor}">

        <!-- Header: Liked Songs-style tile + accent title -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="32,28,32,12">
            <Border Grid.Column="0"
                    Width="288"
                    Height="288"
                    CornerRadius="16"
                    ClipToBounds="True"
                    Margin="0,0,48,0"
                    Background="Black"
                    BoxShadow="0 16 40 0 #60000000"
                    VerticalAlignment="Top">
                <Border Background="Black"
                        BorderBrush="{DynamicResource PrimaryColor}"
                        BorderThickness="3"
                        CornerRadius="16">
                    <PathIcon Width="140" Height="140"
                              Foreground="{DynamicResource PrimaryColor}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" />
                </Border>
            </Border>

            <Grid Grid.Column="1" Height="288" VerticalAlignment="Top">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Liked Albums"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryColor}"
                               LineHeight="64"
                               TextTrimming="CharacterEllipsis"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                    <TextBlock Text="{Binding AlbumStatsText}"
                               Margin="0,28,0,0"
                               FontSize="12"
                               Foreground="#B3B3B3"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Album grid -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Theme="{StaticResource MaterialModernScrollViewer}">
            <Panel Margin="24,0,24,24">
                <TextBlock Text="Albums you like will show up here — tap the heart on any album."
                           FontSize="14"
                           Foreground="#A0A0A0"
                           Margin="8,12,0,0"
                           FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                           IsVisible="{Binding !HasAlbums}" />

                <ItemsControl ItemsSource="{Binding Albums}" IsVisible="{Binding HasAlbums}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Border Classes="AlbumCard"
                                    PointerPressed="OnAlbumCardPressed"
                                    ToolTip.Tip="Open album">
                                <StackPanel Spacing="10">
                                    <Panel Width="160" Height="160">
                                        <Border CornerRadius="8"
                                                ClipToBounds="True"
                                                Background="#2A2A2A">
                                            <Panel>
                                                <Border Background="#3A3A3A"
                                                        IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                                <Image Source="{Binding Artwork}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            </Panel>
                                        </Border>

                                        <Button Classes="CardLike"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,6,6,0"
                                                Command="{Binding $parent[UserControl].((viewModels:LikedAlbumsViewModel)DataContext).UnlikeAlbumCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Remove from Liked Albums">
                                            <PathIcon Width="15" Height="15"
                                                      Foreground="{DynamicResource PrimaryColor}"
                                                      Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" />
                                        </Button>

                                        <Button Classes="CardPlay"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,8,8"
                                                Command="{Binding $parent[UserControl].((viewModels:LikedAlbumsViewModel)DataContext).PlayAlbumCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Play album">
                                            <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                                                 Width="20" Height="20"
                                                 Css="path { fill: #111111; }" />
                                        </Button>
                                    </Panel>

                                    <StackPanel Spacing="3" Width="160">
                                        <TextBlock Text="{Binding Title}" Classes="CardTitle" />
                                        <TextBlock Text="{Binding Artist}" Classes="CardSubtitle" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Panel>
        </ScrollViewer>
    </Grid>
</UserControl>
