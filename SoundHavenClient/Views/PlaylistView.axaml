<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:helpers="clr-namespace:SoundHaven.Helpers"
             xmlns:models="clr-namespace:SoundHaven.Models"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="SoundHaven.Views.PlaylistView"
             x:DataType="viewModels:PlaylistViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.PlaylistTitle">
            <Setter Property="FontSize" Value="42" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="TextBlock.PlaylistMeta">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#A0A0A0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Playlist header title: white normally, dynamic accent for Liked Songs. -->
        <Style Selector="TextBlock.HeaderTitle">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="TextBlock.HeaderTitle.LikedTitle">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.TrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="TextBlock.TrackTitle.Playing">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.TrackMeta">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.ColumnHeader">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.8" />
        </Style>

        <Style Selector="Button.PlaylistAction">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="Button.PlaylistHeroAction">
            <Setter Property="Height" Value="56" />
            <Setter Property="Width" Value="288" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.PlaylistUtility">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="Transparent"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.PlaylistUtility:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <!-- Per-row ⋯ button: hidden until the row is hovered -->
        <Style Selector="Button.RowMore">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="DataGridRow:pointerover Button.RowMore">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- Per-row action cluster (like / download / more): dim until the row is
             hovered, so download progress and liked state stay glanceable. -->
        <Style Selector="StackPanel.RowActions">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="DataGridRow:pointerover StackPanel.RowActions">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.RowActionButton">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.RowActionButton:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.RowMore:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.RowMore:pressed">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid x:Name="RootGrid" ColumnDefinitions="Auto,*">
                        <Border x:Name="PART_Border"
                                Grid.Column="0"
                                Width="20"
                                Height="20"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryColor}"
                                BorderThickness="2"
                                CornerRadius="10">
                            <Ellipse x:Name="PART_CheckGlyph"
                                     Width="12"
                                     Height="12"
                                     Fill="{DynamicResource PrimaryColor}"
                                     Opacity="0" />
                        </Border>
                        <ContentPresenter x:Name="PART_ContentPresenter"
                                          Grid.Column="1"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="CheckBox:pointerover /template/ Border#PART_Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource PrimaryColor}" Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="CheckBox:checked /template/ Ellipse#PART_CheckGlyph">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="56" />
        </Style>

        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#14FFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>

        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#1FFFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <SolidColorBrush x:Key="MaterialSelectionBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.1" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource ToolbarColor}">

        <!-- Playlist header -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="32,28,32,4"
              IsVisible="{Binding HasPlaylist}">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <!-- Cover: dominant square matching reference proportions -->
                <Border Grid.Column="0"
                        Width="288"
                        Height="288"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Margin="0,0,48,0"
                        Background="#1A1A1A"
                        BoxShadow="0 16 40 0 #60000000"
                        VerticalAlignment="Top">
                    <Panel>
                        <Border Background="#3A3A3A"
                                IsVisible="{Binding !HasCoverArt}" />
                        <Image Source="{Binding CoverSlot0}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding HasSingleCover}" />
                        <UniformGrid Rows="2" Columns="2" IsVisible="{Binding HasMosaicCover}">
                            <Image Source="{Binding CoverSlot0}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot1}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot2}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot3}" Stretch="UniformToFill" />
                        </UniformGrid>

                        <!-- Liked Songs note tile: black backing (hides the container
                             corners so no gray shows) plus a thin white outline flush
                             to the outer edge, rounded to match the container. -->
                        <Border IsVisible="{Binding IsLikedSongsPlaylist}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Black">
                            <Border Background="Black"
                                    BorderBrush="{DynamicResource PrimaryColor}"
                                    BorderThickness="3"
                                    CornerRadius="16">
                                <PathIcon Width="150" Height="150"
                                          Foreground="{DynamicResource PrimaryColor}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Data="F1 M6 13c0 1.105-1.12 2-2.5 2S1 14.105 1 13c0-1.104 1.12-2 2.5-2s2.5.896 2.5 2zm9-2c0 1.105-1.12 2-2.5 2s-2.5-.895-2.5-2 1.12-2 2.5-2 2.5.895 2.5 2zM14 11V2h1v9zM6 3v10H5V3zM5 2.905a1 1 0 0 1 .9-.995l8-.8a1 1 0 0 1 1.1.995V3L5 4z" />
                            </Border>
                        </Border>

                        <!-- Downloaded Songs arrow tile: same treatment as the Liked
                             tile, with a download glyph. -->
                        <Border IsVisible="{Binding IsDownloadsPlaylist}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Black">
                            <Border Background="Black"
                                    BorderBrush="{DynamicResource PrimaryColor}"
                                    BorderThickness="3"
                                    CornerRadius="16">
                                <PathIcon Width="150" Height="150"
                                          Foreground="{DynamicResource PrimaryColor}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M5,20h14v-2H5V20z M19,9h-4V3H9v6H5l7,7L19,9z" />
                            </Border>
                        </Border>
                    </Panel>
                </Border>

                <!-- Title / description / stats: vertically centered to cover -->
                <Grid Grid.Column="1"
                      Height="288"
                      VerticalAlignment="Top">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding PlaylistName}"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Classes="HeaderTitle"
                                   Classes.LikedTitle="{Binding IsSystemPlaylist}"
                                   LineHeight="64"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />

                        <TextBlock Text="{Binding PlaylistDescription}"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#A7A7A7"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                                   IsVisible="{Binding HasPlaylistDescription}" />

                        <TextBlock Text="{Binding TrackStatsText}"
                                   Margin="0,28,0,0"
                                   FontSize="12"
                                   Foreground="#B3B3B3"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Play / Shuffle left, Edit / More right — same baseline -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  Margin="0,20,0,8">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="14"
                            VerticalAlignment="Center">
                    <Button Classes="PlaylistHeroAction"
                            Command="{Binding PlayPlaylistCommand}"
                            Background="White"
                            Foreground="#111111"
                            BorderThickness="0"
                            ToolTip.Tip="Play playlist"
                            IsVisible="{Binding !IsEditMode}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                                 Width="22" Height="22"
                                 Css="path { fill: #111111; }" />
                            <TextBlock Text="Play"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="#111111"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistHeroAction"
                            Command="{Binding ShufflePlaylistCommand}"
                            Background="#2A2A2A"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip.Tip="Shuffle play"
                            IsVisible="{Binding !IsEditMode}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/shuffle.svg"
                                 Width="22" Height="22" />
                            <TextBlock Text="Shuffle"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistAction"
                            Command="{Binding DeleteSelectedSongsCommand}"
                            Theme="{StaticResource MaterialOutlineButton}"
                            Foreground="{DynamicResource PrimaryColor}"
                            BorderBrush="{DynamicResource PrimaryColor}"
                            Content="Delete"
                            IsVisible="{Binding IsEditMode}"
                            ToolTip.Tip="Delete selected songs" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button Classes="PlaylistUtility"
                            Command="{Binding CancelRemoveSongsCommand}"
                            ToolTip.Tip="Cancel"
                            Width="56"
                            Height="56"
                            IsVisible="{Binding IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="Cancel"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistUtility"
                            Command="{Binding DownloadAllCommand}"
                            ToolTip.Tip="{Binding DownloadButtonTooltip}"
                            Width="88"
                            Height="56"
                            IsVisible="{Binding ShowDownloadButton}"
                            IsEnabled="{Binding !IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Panel Width="24" Height="24">
                                <!-- Not downloaded: download glyph (shared with search) -->
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/download.svg"
                                     Width="21" Height="21"
                                     Opacity="0.8"
                                     IsVisible="{Binding IsPlaylistNotDownloaded}" />
                                <!-- Downloading: progress ring (click to cancel); the
                                     label shows the live percentage. -->
                                <ProgressBar Classes="circular"
                                             Width="22" Height="22"
                                             Value="{Binding DownloadAllProgress}"
                                             IsVisible="{Binding IsPlaylistDownloading}"
                                             Foreground="{DynamicResource PrimaryColor}" />
                                <!-- Downloaded: check in the dynamic accent -->
                                <PathIcon Width="20" Height="20"
                                          Foreground="{DynamicResource PrimaryColor}"
                                          IsVisible="{Binding IsPlaylistDownloaded}"
                                          Data="M9,16.17 L4.83,12 l-1.42,1.41 L9,19 L21,7 l-1.41,-1.41 z" />
                            </Panel>
                            <TextBlock Text="{Binding DownloadButtonLabel}"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistUtility"
                            Command="{Binding OpenEditPlaylistCommand}"
                            ToolTip.Tip="Edit playlist"
                            Width="56"
                            Height="56"
                            IsVisible="{Binding !IsSystemPlaylist}"
                            IsEnabled="{Binding !IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/edit.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="Edit"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="MoreMenuButton"
                            Classes="PlaylistUtility"
                            ToolTip.Tip="More"
                            Width="56"
                            Height="56"
                            Click="OnMoreButtonClick"
                            IsEnabled="{Binding !IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/more_vert.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="More"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Empty state -->
        <TextBlock Grid.Row="0"
                   Text="Select a playlist to get started"
                   Classes="PlaylistMeta"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,48,0,24"
                   IsVisible="{Binding !HasPlaylist}" />

        <!-- Filter bar -->
        <Border Grid.Row="1"
                Margin="28,12,28,8"
                Background="#14FFFFFF"
                CornerRadius="8"
                Padding="12,0"
                Height="42"
                IsVisible="{Binding HasPlaylist}">
            <Grid ColumnDefinitions="Auto,*">
                <Svg Grid.Column="0"
                     Path="avares://SoundHavenClient/Assets/Icons/search.svg"
                     Width="16" Height="16"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     Opacity="0.55" />
                <TextBox Grid.Column="1"
                         Text="{Binding FilterText, Mode=TwoWay}"
                         Watermark="Filter playlist on title, artist or album"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                         FontSize="14"
                         Foreground="White" />
            </Grid>
        </Border>

        <!-- Track list -->
        <DataGrid x:Name="TrackGrid"
                  Grid.Row="2"
                  Margin="16,0,16,16"
                  ItemsSource="{Binding TrackRows}"
                  SelectedItem="{Binding SelectedTrackRow}"
                  SelectionChanged="OnSelectionChanged"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  IsReadOnly="True"
                  IsVisible="{Binding HasPlaylist}"
                  helpers:DataGridHelper.SelectedItems="{Binding SelectedItems}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header=""
                                        Width="48"
                                        IsVisible="{Binding $parent[UserControl].((viewModels:PlaylistViewModel)DataContext).IsEditMode}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <CheckBox IsChecked="{Binding Song.IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="#" Width="48">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Number}"
                                           Classes="TrackMeta"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding !IsCurrentlyPlaying}" />
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/sound.svg"
                                     Width="14" Height="14"
                                     IsVisible="{Binding IsCurrentlyPlaying}" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TITLE" Width="2.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,4">
                                <Border Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        CornerRadius="4"
                                        ClipToBounds="True"
                                        Margin="0,0,12,0"
                                        Background="#22FFFFFF">
                                    <Panel>
                                        <Image Source="{Binding Song.Artwork}"
                                               Stretch="UniformToFill"
                                               IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Border Background="#3A3A3A"
                                                IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                    </Panel>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Song.Title}"
                                           Classes="TrackTitle"
                                           Classes.Playing="{Binding IsCurrentlyPlaying}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ARTIST" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Artist}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ALBUM" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Album}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="YEAR" Width="64">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Year}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TIME" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Duration, Converter={StaticResource TimeSpanToMinutesSecondsConverter}}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header=""
                                        Width="128"
                                        IsVisible="{Binding !$parent[UserControl].((viewModels:PlaylistViewModel)DataContext).IsEditMode}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <StackPanel Classes="RowActions"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,4,0"
                                        PointerPressed="OnRowActionsPointerPressed">
                                <!-- More options -->
                                <Button Classes="RowActionButton"
                                        Click="OnRowMoreButtonClick"
                                        ToolTip.Tip="More options">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                         Width="18" Height="18" Opacity="0.9" />
                                </Button>

                                <!-- Download (tri-state) -->
                                <Panel Width="34" Height="34">
                                    <Button Classes="RowActionButton"
                                            Command="{Binding $parent[UserControl].((viewModels:PlaylistViewModel)DataContext).DownloadSongCommand}"
                                            CommandParameter="{Binding Song}"
                                            IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.NotDownloaded}}"
                                            ToolTip.Tip="Download">
                                        <Svg Path="avares://SoundHavenClient/Assets/Icons/download.svg"
                                             Width="18" Height="18" Opacity="0.9" />
                                    </Button>
                                    <ProgressBar Classes="circular"
                                                 Width="22" Height="22"
                                                 IsHitTestVisible="False"
                                                 Value="{Binding Song.DownloadProgress}"
                                                 IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.Downloading}}"
                                                 Foreground="{DynamicResource PrimaryColor}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    <Button Classes="RowActionButton"
                                            Command="{Binding $parent[UserControl].((viewModels:PlaylistViewModel)DataContext).RemoveDownloadCommand}"
                                            CommandParameter="{Binding Song}"
                                            IsVisible="{Binding Song.CurrentDownloadState, Converter={StaticResource EnumEqualityConverter}, ConverterParameter={x:Static models:DownloadState.Downloaded}}"
                                            ToolTip.Tip="Remove download">
                                        <PathIcon Width="18" Height="18"
                                                  Foreground="{DynamicResource PrimaryColor}"
                                                  Data="M9,16.17 L4.83,12 l-1.42,1.41 L9,19 L21,7 l-1.41,-1.41 z" />
                                    </Button>
                                </Panel>

                                <!-- Like (heart) -->
                                <Button Classes="RowActionButton"
                                        Command="{Binding $parent[UserControl].((viewModels:PlaylistViewModel)DataContext).ToggleLikeCommand}"
                                        CommandParameter="{Binding Song}"
                                        ToolTip.Tip="Add to Liked Songs">
                                    <Panel>
                                        <PathIcon Width="17" Height="17"
                                                  Foreground="#B3B3B3"
                                                  IsVisible="{Binding !IsLiked}"
                                                  Data="M16.5,3c-1.74,0-3.41,0.81-4.5,2.09C10.91,3.81,9.24,3,7.5,3C4.42,3,2,5.42,2,8.5c0,3.78,3.4,6.86,8.55,11.54L12,21.35l1.45-1.32C18.6,15.36,22,12.28,22,8.5C22,5.42,19.58,3,16.5,3z M12.1,18.55l-0.1,0.1l-0.1-0.1C7.14,14.24,4,11.39,4,8.5C4,6.5,5.5,5,7.5,5c1.54,0,3.04,0.99,3.57,2.36h1.87C13.46,5.99,14.96,5,16.5,5c2,0,3.5,1.5,3.5,3.5C20,11.39,16.86,14.24,12.1,18.55z" />
                                        <PathIcon Width="17" Height="17"
                                                  Foreground="{DynamicResource PrimaryColor}"
                                                  IsVisible="{Binding IsLiked}"
                                                  Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" />
                                    </Panel>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
