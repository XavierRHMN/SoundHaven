<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:helpers="clr-namespace:SoundHaven.Helpers"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="SoundHaven.Views.PlaylistView"
             x:DataType="viewModels:PlaylistViewModel">

    <UserControl.Styles>
        <Style Selector="TextBox.PlaylistTitle">
            <Setter Property="FontSize" Value="42" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <Style Selector="TextBlock.PlaylistMeta">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#A0A0A0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.TrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="TextBlock.TrackTitle.Playing">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.TrackMeta">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#C8C8C8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.ColumnHeader">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LetterSpacing" Value="0.8" />
        </Style>

        <Style Selector="Button.PlaylistAction">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style Selector="Button.PlaylistHeroAction">
            <Setter Property="Height" Value="56" />
            <Setter Property="Width" Value="288" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.PlaylistUtility">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Background="Transparent"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center" />
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.PlaylistUtility:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <!-- Per-row ⋯ button: hidden until the row is hovered -->
        <Style Selector="Button.RowMore">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="DataGridRow:pointerover Button.RowMore">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.RowMore:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.RowMore:pressed">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>

        <Style Selector="CheckBox">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid x:Name="RootGrid" ColumnDefinitions="Auto,*">
                        <Border x:Name="PART_Border"
                                Grid.Column="0"
                                Width="20"
                                Height="20"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryColor}"
                                BorderThickness="2"
                                CornerRadius="10">
                            <Ellipse x:Name="PART_CheckGlyph"
                                     Width="12"
                                     Height="12"
                                     Fill="{DynamicResource PrimaryColor}"
                                     Opacity="0" />
                        </Border>
                        <ContentPresenter x:Name="PART_ContentPresenter"
                                          Grid.Column="1"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="CheckBox:pointerover /template/ Border#PART_Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{DynamicResource PrimaryColor}" Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="CheckBox:checked /template/ Ellipse#PART_CheckGlyph">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="56" />
        </Style>

        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#14FFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>

        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#1FFFFFFF" />
            <Setter Property="RadiusX" Value="8" />
            <Setter Property="RadiusY" Value="8" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <SolidColorBrush x:Key="MaterialSelectionBrush" Color="{DynamicResource PrimaryColor}" Opacity="0.1" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Background="{DynamicResource ToolbarColor}">

        <!-- Playlist header -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="32,28,32,4"
              IsVisible="{Binding HasPlaylist}">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                <!-- Cover: dominant square matching reference proportions -->
                <Border Grid.Column="0"
                        Width="288"
                        Height="288"
                        CornerRadius="4"
                        ClipToBounds="True"
                        Margin="0,0,48,0"
                        Background="#1A1A1A"
                        BoxShadow="0 16 40 0 #60000000"
                        VerticalAlignment="Top">
                    <Panel>
                        <Border Background="#3A3A3A"
                                IsVisible="{Binding !HasCoverArt}" />
                        <Image Source="{Binding CoverSlot0}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding HasSingleCover}" />
                        <UniformGrid Rows="2" Columns="2" IsVisible="{Binding HasMosaicCover}">
                            <Image Source="{Binding CoverSlot0}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot1}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot2}" Stretch="UniformToFill" />
                            <Image Source="{Binding CoverSlot3}" Stretch="UniformToFill" />
                        </UniformGrid>

                        <!-- Liked Songs always shows the eighth-note tile. -->
                        <Border IsVisible="{Binding IsLikedSongsPlaylist}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#7B2FF7" Offset="0" />
                                    <GradientStop Color="#4364F7" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <PathIcon Width="120" Height="120"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Data="M470.38 1.51L150.41 96A32 32 0 0 0 128 126.51v261.41A139 139 0 0 0 96 384c-53 0-96 28.66-96 64s43 64 96 64 96-28.66 96-64V214.32l256-75v184.61a138.4 138.4 0 0 0-32-3.93c-53 0-96 28.66-96 64s43 64 96 64 96-28.65 96-64V32a32 32 0 0 0-41.62-30.49z" />
                        </Border>
                    </Panel>
                </Border>

                <!-- Title / description / stats: vertically centered to cover -->
                <Grid Grid.Column="1"
                      Height="288"
                      VerticalAlignment="Top">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding PlaylistName}"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   LineHeight="64"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />

                        <TextBlock Text="{Binding PlaylistDescription}"
                                   Margin="0,6,0,0"
                                   FontSize="15"
                                   Foreground="#A7A7A7"
                                   TextWrapping="Wrap"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                                   IsVisible="{Binding HasPlaylistDescription}" />

                        <TextBlock Text="{Binding TrackStatsText}"
                                   Margin="0,28,0,0"
                                   FontSize="12"
                                   Foreground="#B3B3B3"
                                   FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Play / Shuffle left, Edit / More right — same baseline -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  Margin="0,20,0,8">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="14"
                            VerticalAlignment="Center">
                    <Button Classes="PlaylistHeroAction"
                            Command="{Binding PlayPlaylistCommand}"
                            Background="White"
                            Foreground="#111111"
                            BorderThickness="0"
                            ToolTip.Tip="Play playlist"
                            IsVisible="{Binding !IsEditMode}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/play.svg"
                                 Width="22" Height="22"
                                 Css="path { fill: #111111; }" />
                            <TextBlock Text="Play"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="#111111"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistHeroAction"
                            Command="{Binding ShufflePlaylistCommand}"
                            Background="#2A2A2A"
                            Foreground="White"
                            BorderThickness="0"
                            ToolTip.Tip="Shuffle play"
                            IsVisible="{Binding !IsEditMode}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/shuffle.svg"
                                 Width="22" Height="22" />
                            <TextBlock Text="Shuffle"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistAction"
                            Command="{Binding DeleteSelectedSongsCommand}"
                            Theme="{StaticResource MaterialOutlineButton}"
                            Foreground="{DynamicResource PrimaryColor}"
                            BorderBrush="{DynamicResource PrimaryColor}"
                            Content="Delete"
                            IsVisible="{Binding IsEditMode}"
                            ToolTip.Tip="Delete selected songs" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button Classes="PlaylistUtility"
                            Command="{Binding CancelRemoveSongsCommand}"
                            ToolTip.Tip="Cancel"
                            Width="56"
                            Height="56"
                            IsVisible="{Binding IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="Cancel"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button Classes="PlaylistUtility"
                            Command="{Binding OpenEditPlaylistCommand}"
                            ToolTip.Tip="Edit playlist"
                            Width="56"
                            Height="56"
                            IsVisible="{Binding !IsLikedSongsPlaylist}"
                            IsEnabled="{Binding !IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/edit.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="Edit"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="MoreMenuButton"
                            Classes="PlaylistUtility"
                            ToolTip.Tip="More"
                            Width="56"
                            Height="56"
                            Click="OnMoreButtonClick"
                            IsEnabled="{Binding !IsEditMode}">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/more_vert.svg"
                                 Width="20" Height="20"
                                 HorizontalAlignment="Center" />
                            <TextBlock Text="More"
                                       FontSize="11"
                                       Foreground="#C8C8C8"
                                       HorizontalAlignment="Center"
                                       FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Empty state -->
        <TextBlock Grid.Row="0"
                   Text="Select a playlist to get started"
                   Classes="PlaylistMeta"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,48,0,24"
                   IsVisible="{Binding !HasPlaylist}" />

        <!-- Filter bar -->
        <Border Grid.Row="1"
                Margin="28,12,28,8"
                Background="#14FFFFFF"
                CornerRadius="8"
                Padding="12,0"
                Height="42"
                IsVisible="{Binding HasPlaylist}">
            <Grid ColumnDefinitions="Auto,*">
                <Svg Grid.Column="0"
                     Path="avares://SoundHavenClient/Assets/Icons/search.svg"
                     Width="16" Height="16"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     Opacity="0.55" />
                <TextBox Grid.Column="1"
                         Text="{Binding FilterText, Mode=TwoWay}"
                         Watermark="Filter playlist on title, artist or album"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular"
                         FontSize="14"
                         Foreground="White" />
            </Grid>
        </Border>

        <!-- Track list -->
        <DataGrid x:Name="TrackGrid"
                  Grid.Row="2"
                  Margin="16,0,16,16"
                  ItemsSource="{Binding TrackRows}"
                  SelectedItem="{Binding SelectedTrackRow}"
                  SelectionChanged="OnSelectionChanged"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  SelectionMode="Extended"
                  IsReadOnly="True"
                  IsVisible="{Binding HasPlaylist}"
                  helpers:DataGridHelper.SelectedItems="{Binding SelectedItems}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header=""
                                        Width="48"
                                        IsVisible="{Binding $parent[UserControl].((viewModels:PlaylistViewModel)DataContext).IsEditMode}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <CheckBox IsChecked="{Binding Song.IsSelected, Mode=TwoWay}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="#" Width="48">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Number}"
                                           Classes="TrackMeta"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding !IsCurrentlyPlaying}" />
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/sound.svg"
                                     Width="14" Height="14"
                                     IsVisible="{Binding IsCurrentlyPlaying}" />
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TITLE" Width="2.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Grid ColumnDefinitions="Auto,*" Margin="0,4">
                                <Border Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        CornerRadius="4"
                                        ClipToBounds="True"
                                        Margin="0,0,12,0"
                                        Background="#22FFFFFF">
                                    <Panel>
                                        <Image Source="{Binding Song.Artwork}"
                                               Stretch="UniformToFill"
                                               IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <Border Background="#3A3A3A"
                                                IsVisible="{Binding Song.Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                                    </Panel>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Song.Title}"
                                           Classes="TrackTitle"
                                           Classes.Playing="{Binding IsCurrentlyPlaying}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ARTIST" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Artist}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ALBUM" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Album}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="YEAR" Width="64">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Year}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TIME" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <TextBlock Text="{Binding Song.Duration, Converter={StaticResource TimeSpanToMinutesSecondsConverter}}"
                                       Classes="TrackMeta"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header=""
                                        Width="56"
                                        IsVisible="{Binding !$parent[UserControl].((viewModels:PlaylistViewModel)DataContext).IsEditMode}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="viewModels:PlaylistTrackRow">
                            <Button Classes="RowMore"
                                    Width="36"
                                    Height="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    PointerPressed="OnRowActionsPointerPressed"
                                    Click="OnRowMoreButtonClick"
                                    ToolTip.Tip="More options">
                                <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                     Width="20" Height="20"
                                     Opacity="0.9" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
