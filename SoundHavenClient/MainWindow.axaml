<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
        xmlns:views="clr-namespace:SoundHaven.Views"
        xmlns:controls="clr-namespace:SoundHaven.Controls"
        mc:Ignorable="d"
        d:DesignWidth="1500" d:DesignHeight="600"
        x:Class="SoundHaven.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/Icons/SoundHavenClient.ico"
        Title="SoundHaven"
        Width="1500" Height="800"
        MinWidth="1200" MinHeight="600"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Window">
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="PART_TransparencyFallback" IsHitTestVisible="False" />
                        <Border Background="{TemplateBinding Background}" IsHitTestVisible="False" />
                        <Panel Background="Transparent" Margin="{TemplateBinding WindowDecorationMargin}" />
                        <VisualLayerManager>
                            <VisualLayerManager.ChromeOverlayLayer>
                                <TitleBar />
                            </VisualLayerManager.ChromeOverlayLayer>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </VisualLayerManager>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.TitleBarButton">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="100" />
        </Style>

        <!-- Small round icon buttons in the bottom player bar -->
        <Style Selector="Button.PlayerBarIcon">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.PlayerBarIcon:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.PlayerBarIcon.Selected">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>
    </Window.Styles>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="92" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#FF1E1E1E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Assets/Icons/SoundHavenClient.ico" Margin="5"/>
            <TextBlock Grid.Column="1" Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                       VerticalAlignment="Center" Margin="5" Foreground="White" />

            <!-- Draggable region -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" Background="Transparent"
                    PointerPressed="OnPointerPressedTitleBar" />

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Click="MaximizeRestoreButton_Click" Classes="TitleBarButton" Margin="0 0 10 0" Background="LawnGreen" />
                <Button Click="MinimizeButton_Click" Classes="TitleBarButton" Margin="0 0 10 0" Background="Gold"/>
                <Button Click="CloseButton_Click" Classes="TitleBarButton"  Margin="0 0 15 0" Background="Red"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Background="{DynamicResource ToolbarColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource ToolbarColor}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="#22FFFFFF"
                    ClipToBounds="True">
                <controls:ToolbarControl DataContext="{Binding ToolbarViewModel}" />
            </Border>

            <!-- All views stay attached; navigation only toggles visibility so
                 switches don't pay layout/texture-upload costs every click. -->
            <Border Grid.Column="1" Background="{DynamicResource ToolbarColor}">
                <Panel>
                    <views:HomeView DataContext="{Binding HomeViewModel}"
                                    IsVisible="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).IsHomeVisible}" />
                    <views:PlaylistView DataContext="{Binding PlaylistViewModel}"
                                        IsVisible="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).IsPlaylistVisible}" />
                    <views:AlbumView DataContext="{Binding AlbumViewModel}"
                                     IsVisible="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).IsAlbumVisible}" />
                    <views:PlayerView DataContext="{Binding PlayerViewModel}"
                                      IsVisible="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).IsPlayerVisible}" />
                </Panel>
            </Border>

            <!-- Dockable play queue: pushes content left when toggled on -->
            <Border Grid.Column="2"
                    Width="340"
                    Background="{DynamicResource ToolbarColor}"
                    BorderThickness="1,0,0,0"
                    BorderBrush="#22FFFFFF"
                    IsVisible="{Binding IsQueueVisible}">
                <controls:PlayQueueControl DataContext="{Binding PlayerViewModel}" />
            </Border>
        </Grid>

        <!-- Player Controls (TIDAL-style: now playing | transport + seek | extras) -->
        <Grid Grid.Row="2" Background="{DynamicResource PlayerBarColor}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: now playing + favorite/more placeholders -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center"
                        Margin="16,0,8,0"
                        ClipToBounds="True">
                <controls:SongInfoControl DataContext="{Binding SongInfoViewModel}"
                                          VerticalAlignment="Center" />
                <Button Classes="PlayerBarIcon"
                        VerticalAlignment="Center"
                        Command="{Binding ToggleFavoriteCommand}"
                        ToolTip.Tip="Add to Liked Songs">
                    <Panel>
                        <!-- Outline heart when not liked -->
                        <PathIcon Width="18" Height="18"
                                  Foreground="#B3B3B3"
                                  IsVisible="{Binding !IsCurrentSongFavorite}"
                                  Data="M16.5,3c-1.74,0-3.41,0.81-4.5,2.09C10.91,3.81,9.24,3,7.5,3C4.42,3,2,5.42,2,8.5c0,3.78,3.4,6.86,8.55,11.54L12,21.35l1.45-1.32C18.6,15.36,22,12.28,22,8.5C22,5.42,19.58,3,16.5,3z M12.1,18.55l-0.1,0.1l-0.1-0.1C7.14,14.24,4,11.39,4,8.5C4,6.5,5.5,5,7.5,5c1.54,0,3.04,0.99,3.57,2.36h1.87C13.46,5.99,14.96,5,16.5,5c2,0,3.5,1.5,3.5,3.5C20,11.39,16.86,14.24,12.1,18.55z" />
                        <!-- Filled accent heart when liked -->
                        <PathIcon Width="18" Height="18"
                                  Foreground="{DynamicResource PrimaryColor}"
                                  IsVisible="{Binding IsCurrentSongFavorite}"
                                  Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" />
                    </Panel>
                </Button>
                <Button Classes="PlayerBarIcon"
                        VerticalAlignment="Center"
                        Click="OnNowPlayingMoreClick"
                        ToolTip.Tip="More options">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                         Width="18" Height="18"
                         Opacity="0.75" />
                </Button>
            </StackPanel>

            <!-- Center: transport row over the seek bar -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="4">
                    <controls:ShuffleControl DataContext="{Binding ShuffleViewModel}"
                                             VerticalAlignment="Center" />
                    <controls:PlaybackControl DataContext="{Binding PlaybackViewModel}"
                                              VerticalAlignment="Center" />
                    <controls:RepeatControl DataContext="{Binding RepeatViewModel}"
                                            VerticalAlignment="Center" />
                </StackPanel>
                <controls:SeekSliderControl Width="520"
                                            DataContext="{Binding SeekSliderViewModel}"
                                            Margin="0,-4,0,0" />
            </StackPanel>

            <!-- Right: queue/EQ placeholders, volume, mini player, quality badge -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="8,0,16,0">
                <Button Classes="PlayerBarIcon"
                        Classes.Selected="{Binding IsQueueVisible}"
                        VerticalAlignment="Center"
                        Command="{Binding ToggleQueueCommand}"
                        ToolTip.Tip="Play queue">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/queue_music.svg"
                         Width="18" Height="18"
                         Opacity="0.75" />
                </Button>
                <Button Classes="PlayerBarIcon"
                        VerticalAlignment="Center"
                        Click="OnSoundOutputClick"
                        ToolTip.Tip="Sound output">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/speaker.svg"
                         Width="18" Height="18"
                         Opacity="0.75" />
                </Button>
                <Button Classes="PlayerBarIcon"
                        VerticalAlignment="Center"
                        Click="OnMiniPlayerClick"
                        ToolTip.Tip="Mini player">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/miniplayer.svg"
                         Width="18" Height="18"
                         Opacity="0.75" />
                </Button>
                <controls:VolumeControl DataContext="{Binding VolumeViewModel}"
                                        VerticalAlignment="Center" />
                <Border CornerRadius="15"
                        Background="#14FFFFFF"
                        Padding="12,6"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Audio quality">
                    <TextBlock Text="AAC 128 kbps"
                               FontSize="12"
                               Foreground="{DynamicResource PrimaryColor}"
                               FontFamily="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.RowSpan="3"
                ZIndex="1000"
                IsVisible="{Binding Notifications.IsVisible}"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="20,50,20,0"
                Padding="18,10"
                MaxWidth="800"
                CornerRadius="8"
                Background="#EE242424"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                Classes.Error="{Binding Notifications.IsError}">
            <Border.Styles>
                <Style Selector="Border.Error">
                    <Setter Property="BorderBrush" Value="#66E57373" />
                </Style>
            </Border.Styles>
            <TextBlock Text="{Binding Notifications.Message}"
                       Foreground="White"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>