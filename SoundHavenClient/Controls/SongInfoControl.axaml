<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             x:Class="SoundHaven.Controls.SongInfoControl"
             x:DataType="viewModels:SongInfoViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.Title">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.ArtistAndYear">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <!-- Now-playing cover darkens on hover to signal it opens the Player. -->
        <Style Selector="Border.ThumbHover">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.NowPlayingThumb:pointerover Border.ThumbHover">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Actual Song Info -->
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    IsVisible="{Binding CurrentSongExists}">
            <!-- Album cover: spinner while loading; otherwise artwork or gray
                 placeholder. Clicking it opens the Player. -->
            <Border Classes="NowPlayingThumb"
                    CornerRadius="5"
                    ClipToBounds="True"
                    Margin="0,0,20,0"
                    Width="50"
                    Height="50"
                    Cursor="Hand"
                    Background="Transparent"
                    PointerPressed="OnThumbnailPressed"
                    ToolTip.Tip="Open player">
                <Panel>
                    <ProgressBar Classes="circular"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsSeekBuffering}"
                                 Width="30"
                                 Height="30"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource PrimaryColor}" />

                    <Panel IsVisible="{Binding !IsSeekBuffering}">
                        <Border Background="#3A3A3A"
                                IsVisible="{Binding CurrentSong.Artwork, Converter={x:Static ObjectConverters.IsNull}}" />
                        <Image Source="{Binding CurrentSong.Artwork}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding CurrentSong.Artwork, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Panel>

                    <Border Classes="ThumbHover" Background="#66000000" />
                </Panel>
            </Border>

            <!-- Song Information -->
            <StackPanel Orientation="Vertical">
                <!-- Title with continuous scrolling effect. The reserved width
                     hugs short titles and caps at ControlWidth for long ones. -->
                <Border ClipToBounds="True" Width="{Binding TitleWidth}" Height="25"
                        HorizontalAlignment="Left" Background="Transparent">
                    <Canvas Width="{Binding TitleWidth}" Height="25">
                        <!-- First TextBlock -->
                        <TextBlock Text="{Binding CurrentSong.Title}"
                                   Classes="Title"
                                   Canvas.Left="{Binding TitleScrollPosition1}" />

                        <!-- Second TextBlock, positioned to the right of the first -->
                        <TextBlock Text="{Binding CurrentSong.Title}"
                                   Classes="Title"
                                   Canvas.Left="{Binding TitleScrollPosition2}" />
                    </Canvas>
                </Border>

                <!-- Artist and Year combined (year is resolved online for YouTube tracks) -->
                <TextBlock HorizontalAlignment="Left"
                           Classes="ArtistAndYear"
                           Text="{Binding ArtistAndYearText}" />
            </StackPanel>
        </StackPanel>

        <!-- Placeholder Song Info (when no current song exists) -->
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    IsVisible="{Binding !CurrentSongExists}">
            <!-- Placeholder Album Cover -->
            <Border CornerRadius="5"
                    ClipToBounds="True"
                    Margin="0,0,20,0"
                    Width="50"
                    Height="50"
                    Background="#3A3A3A" />

            <!-- Placeholder Song Information -->
            <StackPanel Orientation="Vertical">
                <!-- Placeholder Title -->
                <TextBlock Text="Play a song!"
                           Classes="Title" />

                <!-- Placeholder Artist and Year -->
                <TextBlock Text="Artist - 20XX"
                           Classes="ArtistAndYear" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
