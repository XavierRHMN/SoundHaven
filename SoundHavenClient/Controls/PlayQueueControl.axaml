<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SoundHaven.Models"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:ripple="clr-namespace:Material.Ripple;assembly=Material.Ripple"
             x:Class="SoundHaven.Controls.PlayQueueControl"
             x:DataType="viewModels:PlayerViewModel">

    <UserControl.Styles>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBoxItem:selected /template/ Border#PART_HoverEffect">
            <Setter Property="Opacity" Value="0" />
        </Style>

        <!-- Round the Material hover highlight to match the app's row styling -->
        <Style Selector="ListBoxItem /template/ Border#PART_HoverEffect">
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <!-- History rows render dimmed — they've already been played -->
        <Style Selector="ListBox#HistoryList ListBoxItem">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style Selector="ListBox#HistoryList ListBoxItem:pointerover">
            <Setter Property="Opacity" Value="0.85" />
        </Style>

        <Style Selector="ListBoxItem:pressed /template/ ripple|RippleEffect#PART_Ripple">
            <Setter Property="RippleFill" Value="Transparent" />
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <Style Selector="TextBlock.PanelTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="20" />
        </Style>

        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Margin" Value="0,16,0,8" />
        </Style>

        <Style Selector="TextBlock.SongTrackTitle">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.SongArtistName">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0 5 0 0" />
        </Style>

        <Style Selector="TextBlock.EmptyQueueHint">
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,4,0,8" />
        </Style>

        <!-- Icon-only overflow: strip Material chrome so no filled background shows. -->
        <Style Selector="Button.IconOnly">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.IconOnly:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.IconOnly:pressed">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16,14,12,8">
        <!-- Header: title + close toggle -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,4,4">
            <TextBlock Text="Play queue"
                       Classes="PanelTitle"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="IconOnly"
                    Width="32"
                    Height="32"
                    Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ToggleQueueCommand}"
                    ToolTip.Tip="Close queue">
                <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                     Width="16" Height="16"
                     Opacity="0.75" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Hidden"
                      Theme="{StaticResource MaterialModernScrollViewer}">
            <StackPanel Margin="0,0,4,16">
                <TextBlock Text="History"
                           Classes="SectionHeader"
                           HorizontalAlignment="Left" />
                <Rectangle Height="1"
                           Fill="White"
                           Opacity="0.1"
                           IsHitTestVisible="False"
                           Margin="0,0,0,8" />

                <TextBlock Text="Songs you've played will show up here"
                           Classes="EmptyQueueHint"
                           IsVisible="{Binding !HasHistorySongs}" />

                <ListBox x:Name="HistoryList"
                         ItemsSource="{Binding HistorySongs}"
                         Background="Transparent"
                         Theme="{StaticResource MaterialModernListBox}"
                         SelectionMode="Single"
                         SelectionChanged="OnHistorySelectionChanged"
                         IsVisible="{Binding HasHistorySongs}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Margin="0,2"
                                  Background="Transparent"
                                  PointerPressed="OnRowRightClickPressed">
                                <Border Grid.Column="0"
                                        CornerRadius="5"
                                        ClipToBounds="True"
                                        Margin="0,0,10,0"
                                        Background="#3A3A3A">
                                    <Image Width="50"
                                           Height="50"
                                           Source="{Binding Artwork}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Orientation="Vertical"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Classes="SongTrackTitle" />
                                    <TextBlock Text="{Binding Artist}"
                                               Classes="SongArtistName" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Classes="IconOnly"
                                        Width="36"
                                        Height="36"
                                        VerticalAlignment="Center"
                                        PointerPressed="OnActionsPointerPressed"
                                        Click="OnRowOverflowButtonClick"
                                        ToolTip.Tip="More options">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/more_vert.svg"
                                         Stretch="Uniform"
                                         Width="20"
                                         Height="20"
                                         Opacity="0.95" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Playing"
                           Classes="SectionHeader"
                           HorizontalAlignment="Left" />
                <Rectangle Height="1"
                           Fill="White"
                           Opacity="0.1"
                           IsHitTestVisible="False"
                           Margin="0,0,0,8" />

                <Border IsVisible="{Binding HasPlayingSong}"
                        Background="#14FFFFFF"
                        CornerRadius="8"
                        Padding="8"
                        Margin="0,0,0,4"
                        PointerPressed="OnPlayingCardPointerPressed">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                CornerRadius="5"
                                ClipToBounds="True"
                                Margin="0,0,10,0"
                                Background="#3A3A3A">
                            <Image Width="50"
                                   Height="50"
                                   Source="{Binding PlayerViewSong.Artwork}"
                                   Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding PlayerViewSong.Title}"
                                       Classes="SongTrackTitle"
                                       Foreground="{DynamicResource PrimaryColor}" />
                            <TextBlock Text="{Binding PlayerViewSong.Artist}"
                                       Classes="SongArtistName" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="IconOnly"
                                Width="36"
                                Height="36"
                                VerticalAlignment="Center"
                                Click="OnPlayingOverflowButtonClick"
                                ToolTip.Tip="More options">
                            <Svg Path="avares://SoundHavenClient/Assets/Icons/more_vert.svg"
                                 Stretch="Uniform"
                                 Width="20"
                                 Height="20"
                                 Opacity="0.95" />
                        </Button>
                    </Grid>
                </Border>
                <TextBlock Text="Nothing playing"
                           Classes="EmptyQueueHint"
                           IsVisible="{Binding !HasPlayingSong}" />

                <TextBlock Text="Up Next"
                           Classes="SectionHeader"
                           HorizontalAlignment="Left" />
                <Rectangle Height="1"
                           Fill="White"
                           Opacity="0.1"
                           IsHitTestVisible="False"
                           Margin="0,0,0,8" />

                <TextBlock Text="Queue is empty — use Play next from search"
                           Classes="EmptyQueueHint"
                           IsVisible="{Binding !HasUpNextSongs}" />

                <ListBox x:Name="UpNextList"
                         ItemsSource="{Binding UpNextSongs}"
                         Background="Transparent"
                         Theme="{StaticResource MaterialModernListBox}"
                         SelectionMode="Single"
                         SelectionChanged="OnSelectionChanged"
                         IsVisible="{Binding HasUpNextSongs}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Song">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                  Margin="0,2"
                                  Background="Transparent"
                                  PointerPressed="OnRowRightClickPressed">
                                <Border Grid.Column="0"
                                        Width="28"
                                        Height="50"
                                        Background="Transparent"
                                        Cursor="SizeAll"
                                        ToolTip.Tip="Drag to reorder"
                                        PointerPressed="OnDragHandlePointerPressed"
                                        PointerMoved="OnDragHandlePointerMoved"
                                        PointerReleased="OnDragHandlePointerReleased"
                                        PointerCaptureLost="OnDragHandlePointerCaptureLost">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/drag_handle.svg"
                                         Width="18"
                                         Height="18"
                                         Stretch="Uniform"
                                         Opacity="0.45"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         IsHitTestVisible="False" />
                                </Border>

                                <Border Grid.Column="1"
                                        CornerRadius="5"
                                        ClipToBounds="True"
                                        Margin="0,0,10,0"
                                        Background="#3A3A3A">
                                    <Image Width="50"
                                           Height="50"
                                           Source="{Binding Artwork}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="2"
                                            Orientation="Vertical"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Classes="SongTrackTitle" />
                                    <TextBlock Text="{Binding Artist}"
                                               Classes="SongArtistName" />
                                </StackPanel>

                                <Button Grid.Column="3"
                                        Classes="IconOnly"
                                        Width="36"
                                        Height="36"
                                        VerticalAlignment="Center"
                                        PointerPressed="OnActionsPointerPressed"
                                        Click="OnRowOverflowButtonClick"
                                        ToolTip.Tip="More options">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/more_vert.svg"
                                         Stretch="Uniform"
                                         Width="20"
                                         Height="20"
                                         Opacity="0.95" />
                                </Button>

                                <Border Grid.Column="4"
                                        Width="32"
                                        Height="50"
                                        Background="Transparent"
                                        Cursor="Hand"
                                        ToolTip.Tip="Remove from Up Next"
                                        PointerPressed="OnRemoveFromUpNextPointerPressed">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/close.svg"
                                         Width="16"
                                         Height="16"
                                         Stretch="Uniform"
                                         Opacity="0.55"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         IsHitTestVisible="False" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
