<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="280" d:DesignHeight="700"
             x:Class="SoundHaven.Controls.ToolbarControl"
             xmlns:viewModels="clr-namespace:SoundHaven.ViewModels"
             xmlns:models="clr-namespace:SoundHaven.Models"
             xmlns:ripple="clr-namespace:Material.Ripple;assembly=Material.Ripple"
             x:DataType="viewModels:ToolbarViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.ToolbarText">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
        </Style>

        <!-- Nav rows share the playlist-row look: rounded 14, translucent hover,
             #2A2A2A + accent text when active. -->
        <Style Selector="Button.NavItem">
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            ClipToBounds="True">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Left"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.NavItem:pointerover /template/ Border#PART_Root">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="Button.NavItem:pressed /template/ Border#PART_Root">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <Style Selector="Button.NavItem.Selected /template/ Border#PART_Root">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>

        <Style Selector="Button.NavItem.Selected TextBlock.ToolbarText">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="TextBlock.PlaylistsHeader">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Bold.otf#Circular" />
        </Style>

        <Style Selector="TextBlock.PlaylistName">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="TextBlock.PlaylistCount">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="FontFamily"
                    Value="avares://SoundHavenClient/Assets/Fonts/Circular/CircularStd-Medium.otf#Circular" />
        </Style>

        <Style Selector="Button.SidebarIcon">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Theme" Value="{x:Null}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalContentAlignment="Center"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.SidebarIcon:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <Style Selector="Button.SidebarIcon:pressed">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>

        <Style Selector="ListBox.PlaylistSidebar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <Style Selector="ListBox.PlaylistSidebar ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="PART_Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="10,8"
                            ClipToBounds="True">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ListBox.PlaylistSidebar ListBoxItem:pointerover /template/ Border#PART_Root">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="ListBox.PlaylistSidebar ListBoxItem:selected /template/ Border#PART_Root">
            <Setter Property="Background" Value="#2A2A2A" />
        </Style>

        <Style Selector="ListBox.PlaylistSidebar ListBoxItem:selected TextBlock.PlaylistName">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}" />
        </Style>

        <Style Selector="ListBox.PlaylistSidebar ListBoxItem:selected Border.PlayingBadge">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="ListBoxItem:pressed /template/ ripple|RippleEffect#PART_Ripple">
            <Setter Property="RippleFill" Value="Transparent" />
            <Setter Property="Opacity" Value="1.0" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{StaticResource ToolbarColor}">
        <!-- Nav -->
        <StackPanel Grid.Row="0" Margin="8,4,8,0">
            <Button Classes="NavItem"
                    Classes.Selected="{Binding IsHomeActive}"
                    Command="{Binding ShowHomeViewCommand}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/home.svg" Width="16" Height="16" />
                    <TextBlock Classes="ToolbarText" Text="Home" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Classes="NavItem"
                    Classes.Selected="{Binding IsPlayerActive}"
                    Command="{Binding ShowPlayerViewCommand}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/player.svg" Width="16" Height="16" />
                    <TextBlock Classes="ToolbarText" Text="Player" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Separator Background="White" Opacity="0.08" Margin="4,8" />
        </StackPanel>

        <!-- All playlists -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,4,0,0">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="16,4,8,12">
                <TextBlock Text="All playlists"
                           Classes="PlaylistsHeader"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Classes="SidebarIcon"
                        Command="{Binding CreatePlaylistCommand}"
                        ToolTip.Tip="Create playlist">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/add_circle.svg"
                         Width="20" Height="20"
                         Opacity="0.75" />
                </Button>

                <Button Grid.Column="2"
                        Classes="SidebarIcon"
                        Click="OnSortButtonClick"
                        ToolTip.Tip="Sort playlists">
                    <Svg Path="avares://SoundHavenClient/Assets/Icons/sort.svg"
                         Width="18" Height="18"
                         Opacity="0.75" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Theme="{StaticResource MaterialModernScrollViewer}">
                <ListBox Classes="PlaylistSidebar"
                         ItemsSource="{Binding PlaylistCollection}"
                         SelectedItem="{Binding ToolbarSelectedPlaylist, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Playlist">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  HorizontalAlignment="Stretch"
                                  Background="Transparent"
                                  PointerPressed="OnPlaylistPointerPressed">
                                <Border Grid.Column="0"
                                        Width="48"
                                        Height="48"
                                        CornerRadius="6"
                                        ClipToBounds="True"
                                        Background="#1A1A1A"
                                        Margin="0,0,12,0"
                                        IsHitTestVisible="False">
                                    <Panel>
                                        <Border Background="#3A3A3A"
                                                IsVisible="{Binding !HasSidebarCover}" />
                                        <Image Source="{Binding SidebarSlot0}"
                                               Stretch="UniformToFill"
                                               IsVisible="{Binding HasSidebarSingleCover}" />
                                        <UniformGrid Rows="2" Columns="2"
                                                     IsVisible="{Binding HasSidebarMosaic}">
                                            <Image Source="{Binding SidebarSlot0}" Stretch="UniformToFill" />
                                            <Image Source="{Binding SidebarSlot1}" Stretch="UniformToFill" />
                                            <Image Source="{Binding SidebarSlot2}" Stretch="UniformToFill" />
                                            <Image Source="{Binding SidebarSlot3}" Stretch="UniformToFill" />
                                        </UniformGrid>

                                        <Border Classes="PlayingBadge"
                                                IsVisible="False"
                                                Background="#66000000"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch">
                                            <Svg Path="avares://SoundHavenClient/Assets/Icons/sound.svg"
                                                 Width="16" Height="16"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        </Border>
                                    </Panel>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Spacing="2"
                                            IsHitTestVisible="False">
                                    <TextBlock Text="{Binding Name}" Classes="PlaylistName" />
                                    <TextBlock Text="{Binding ItemCountText}" Classes="PlaylistCount" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Classes="SidebarIcon"
                                        Width="36"
                                        Height="36"
                                        VerticalAlignment="Center"
                                        PointerPressed="OnOverflowPointerPressed"
                                        Click="OnPlaylistOverflowClick"
                                        ToolTip.Tip="More options">
                                    <Svg Path="avares://SoundHavenClient/Assets/Icons/more_horiz.svg"
                                         Width="20" Height="20"
                                         Opacity="0.75" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
