# Copy to a local .env file or set these as user/system environment variables.
# Never commit real values — .env and *API_KEY*.txt are gitignored.

# Optional Last.fm integration
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-api-secret

# Required for YouTube Music song search (Innertube key from music.youtube.com web client)
YOUTUBE_INNERTUBE_API_KEY=your-innertube-api-key
